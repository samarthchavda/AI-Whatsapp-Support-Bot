# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/whatsapp_support_bot

# Server Configuration
PORT=5000
NODE_ENV=development

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# WhatsApp Configuration (if using API instead of whatsapp-web.js)
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_API_TOKEN=your_whatsapp_api_token

# Admin Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=+1234567890

# Escalation Thresholds
HIGH_PRIORITY_KEYWORDS=urgent,critical,emergency,refund,complaint
ESCALATION_EMAIL=support@example.com
