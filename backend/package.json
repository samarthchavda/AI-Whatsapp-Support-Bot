  "description": "AI-powered WhatsApp Support Bot Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js || node server.js",
    "reset-session": "rm -rf .wwebjs_auth .wwebjs_cache && npm run dev",
    "clear-data": "node scripts/clearUserData.js",
    "seed": "node scripts/seedData.js",
    "reset-demo": "node scripts/clearUserData.js && node scripts/seedData.js",
    "create-admin": "node scripts/createAdmin.js",
    "create-test-admin": "node scripts/createTestAdmin.js",
    "seed-demo": "node scripts/seedDemoAccount.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test-webhook": "node scripts/testWebhook.js",
    "test-webhook:shopify": "node scripts/testWebhook.js shopify",
    "test-webhook:woocommerce": "node scripts/testWebhook.js woocommerce",
    "test-gemini": "node scripts/testGemini.js",
    "verify-gemini": "node scripts/verifyGeminiKey.js"
  },
  "keywords": [
    "whatsapp",
    "ai",
    "support",
    "bot",
    "mern"
  ],
