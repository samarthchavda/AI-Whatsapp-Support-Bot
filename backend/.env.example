# Server Configuration
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/whatsapp-support-bot

# AI Service Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Bot Configuration
HIGH_PRIORITY_KEYWORDS=urgent,critical,emergency,refund,complaint,angry

# Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Webhook Configuration
WEBHOOK_SECRET_TOKEN=your_secure_random_token_here
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret_here
WOOCOMMERCE_WEBHOOK_SECRET=your_woocommerce_webhook_secret_here

# Optional: OpenAI (if using GPT instead of Gemini)
# OPENAI_API_KEY=your_openai_api_key_here

# Email Configuration (for sending credentials)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Frontend URL
FRONTEND_URL=http://localhost:3000
